      "can_view_grades": true,
      "financial_scope": "own_only"
    },
    "Student": {
      "clearance": "Self-Scoped",
      "description": "Access to class info and own financial records only",
      "allowed_resources": [
        "persons",
        "classes"
      ],
      "mask_overrides": [],
